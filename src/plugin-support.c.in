// =============================================================================
// plugin-support.c.in — CMake가 컴파일 직전에 토큰 치환해 .c로 만드는 템플릿
//
// 빌드 흐름:
//   1) cmake/common/helpers_common.cmake가 configure_file()로
//      @CMAKE_PROJECT_NAME@ → "securecast", @CMAKE_PROJECT_VERSION@ → "1.0.0"
//      등으로 치환한 결과를 build_x64/plugin-support.c 에 출력.
//   2) 그 .c가 "plugin-support" 정적 라이브러리로 빌드됨.
//   3) CMakeLists.txt 에서 plugin-support 를 securecast.dll 에 링크.
//   → 결과적으로 PLUGIN_NAME 등이 컴파일 타임 상수로 박힘.
// =============================================================================

#include <stdio.h>
#include <stdarg.h>
#include <stdlib.h>
#include <string.h>

#include <obs.h>             // blogva (OBS 로그 진입점)

#include "plugin-support.h"

const char *PLUGIN_NAME = "@CMAKE_PROJECT_NAME@";
const char *PLUGIN_VERSION = "@CMAKE_PROJECT_VERSION@";

// 호출 형태:
//   obs_log(LOG_INFO, "[tracker] %ls @ ...", exe_name, ...);
//
// 내부에서 "[securecast] " prefix를 붙인 뒤 OBS 로그창에 출력.
// blogva가 va_list를 직접 받기 때문에 vfprintf-스타일 포워딩 가능.
void obs_log(int log_level, const char *format, ...)
{
	// "[%s] " 4글자 + PLUGIN_NAME + format 길이만큼 임시 버퍼 할당.
	size_t length = 4 + strlen(PLUGIN_NAME) + strlen(format);

	char *template = malloc(length + 1);
	snprintf(template, length, "[%s] %s", PLUGIN_NAME, format);
	template[length] = '\0';

	va_list args;
	va_start(args, format);
	blogva(log_level, template, args);
	va_end(args);

	free(template);
}
